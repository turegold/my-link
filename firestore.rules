rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. users 컬렉션 (유저 프로필 및 정보)
    // 읽기: 누구나 가능 (displayName 중복 검사 및 퍼블릭 프로필 페이지 조회용)
    // 쓰기: 로그인한 사용자 && 본인 문서일 때만 가능
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // 2. links 하위 컬렉션 (유저의 링크 목록)
      // 읽기: 누구나 가능 (퍼블릭 프로필 페이지에서 링크 목록을 보여주기 위함)
      // 쓰기: 로그인한 사용자 && 본인의 하위 컬렉션일 때만 가능
      match /links/{linkId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
